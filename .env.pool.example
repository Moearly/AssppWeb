# 账号池环境变量配置示例

# 账号池加密密钥（必需，256-bit）
# 生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCOUNT_POOL_KEY=请运行上面的命令生成并替换此处

# 管理员 API 密钥（必需）
# 用于保护管理员 API 端点
ADMIN_API_KEY=your_admin_secret_key_here

# 数据库路径（可选，默认：data/asspp.db）
DB_PATH=./data/asspp.db

# 是否禁用 HTTPS 重定向（开发环境可设为 true）
UNSAFE_DANGEROUSLY_DISABLE_HTTPS_REDIRECT=false
